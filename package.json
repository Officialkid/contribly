{
  "name": "contribly",
  "version": "0.1.0",
  "description": "Multi-tenant SaaS platform for collaborative contributions",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "node scripts/local-dev.mjs",
    "dev:workspaces": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules",
    "secrets:scan": "node scripts/secret-scan.mjs",
    "db:doctor": "node scripts/prisma-local.mjs doctor",
    "db:setup": "node scripts/prisma-local.mjs setup",
    "db:generate": "node scripts/prisma-local.mjs generate",
    "db:migrate": "node scripts/prisma-local.mjs migrate deploy",
    "db:reset": "node scripts/prisma-local.mjs migrate reset --force",
    "db:push": "node scripts/prisma-local.mjs db push",
    "db:studio": "node scripts/prisma-local.mjs studio",
    "db:status": "node scripts/prisma-local.mjs migrate status",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build:api": "docker build -f apps/api/Dockerfile --target production -t contribly-api .",
    "docker:build:web": "docker build -f apps/web/Dockerfile --target production -t contribly-web .",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.0.0",
    "multer": "^2.0.2"
  }
}
