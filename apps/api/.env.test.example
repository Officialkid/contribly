# Test Environment Configuration
# Copy this to .env.test and fill in your test database URL

# IMPORTANT: Use a separate test database, NEVER use your development or production database
# The test suite will create and delete data during tests
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/contribly_test

# Optional: Override other settings for test environment
# These have defaults in the test setup, but you can override them here
# NODE_ENV=test
# JWT_SECRET=test-jwt-secret
# FRONTEND_URL=http://localhost:3000
